# OpenFlux Prototype Configuration

# Server
PORT=3000
HOST=localhost

# Database
DATA_DIR=./data

# Node operator
NODE_OPERATOR_PUBKEY=
NODE_QUERY_FEE_BPS=50
NODE_TASK_FEE_BPS=100

# Solana
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
ANCHOR_KEYPAIR=

# Hash anchoring
ANCHOR_INTERVAL_MS=300000
ANCHOR_MIN_ITEMS=5

# Rate limits
MAX_PUBLISHES_PER_DAY=10
MAX_BODY_BYTES=65536
MAX_CONCURRENT_TASK_CLAIMS=3

# x402 payment integration
X402_ENABLED=true
X402_FACILITATOR_URL=https://x402.dexter.cash
X402_FACILITATOR_FALLBACK_URL=https://facilitator.payai.network
X402_PAY_TO=<your-solana-address>  # Solana address to receive USDC payments
X402_NETWORK=solana:5eykt4UsFv8P8NJdTREpY1vzqKqZKvdp  # mainnet
